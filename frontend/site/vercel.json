{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://this1-backend.onrender.com/api/$1" },
    { "source": "/_defender/(.*)", "destination": "https://this1-backend.onrender.com/_defender/$1" },
    { "source": "/internal/(.*)", "destination": "https://this1-backend.onrender.com/internal/$1" }
  ]
}
